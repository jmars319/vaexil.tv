ADMIN_PASSWORD="change-this-before-deploy"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
SUGGESTION_READY_VOTE_THRESHOLD="5"

# Local development defaults to a file database at .data/vaexil.db.
# For Vercel/production, use a hosted libSQL/Turso database instead.
# Example hosted value: LIBSQL_URL="libsql://your-database.turso.io"
LIBSQL_URL="file:.data/vaexil.db"
LIBSQL_AUTH_TOKEN=""

# Recon draft assets read from local files by default. Production can set this to
# r2 and provide Cloudflare R2 credentials for protected admin asset delivery.
RECON_ASSET_STORE="local"
CLOUDFLARE_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BUCKET="vaexil-tv-media-public"
R2_PRIVATE_BUCKET="vaexil-tv-media-private"
R2_PUBLIC_BASE_URL="https://cdn.vaexil.tv"
R2_RECON_KEY_PREFIX="recon/"
# Legacy fallback only. Prefer R2_PRIVATE_BUCKET for new Vaexil Recon assets.
R2_BUCKET=""

# Contact email delivery. Form submissions are still recorded if these are unset.
SENDGRID_API_KEY=""
SENDGRID_TO_EMAIL="vaexiltv@gmail.com"
SENDGRID_FROM_EMAIL=""

# Bungie API access for Destiny 2 guide tools. Keep this server-side only.
BUNGIE_API_KEY=""
# Keep draft Destiny guide/tool routes private to signed-in admins until launch.
DESTINY_GUIDES_PUBLIC="false"

NEXT_PUBLIC_SITE_URL="https://vaexil.tv"
NEXT_PUBLIC_TWITCH_URL="https://www.twitch.tv/vaexil"
NEXT_PUBLIC_YOUTUBE_URL="https://www.youtube.com/@Vaexil-Twitch"
NEXT_PUBLIC_DISCORD_URL=""
NEXT_PUBLIC_GITHUB_URL=""
