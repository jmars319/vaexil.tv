{
  "appDir": "src/app",
  "sourceRoots": [
    ".github/workflows",
    "src/app",
    "src/components",
    "src/data",
    "src/lib",
    "docs",
    "scripts"
  ],
  "assetRoots": [
    "public",
    "src/app",
    "private/recon/maps"
  ],
  "generatedArtifactPatterns": [
    ".next/**",
    ".vercel/**",
    ".data/**",
    "_live-reference/**",
    "build/**",
    "dist/**",
    "out/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    "*.tsbuildinfo",
    "next-env.d.ts"
  ],
  "maxImplementationFileLines": 700,
  "maxScriptFileLines": 900,
  "maxStyleFileLines": 400,
  "maxDocFileLines": 1500,
  "nearBudgetLineWindow": 25,
  "maxAssetBytes": 3407872,
  "nearAssetBytes": 102400,
  "failOnWarnings": true,
  "bundleBudget": {
    "maxTotalStaticJsKb": 767,
    "maxWorkerJsKb": 22,
    "maxLargestChunkKb": 240,
    "maxRouteFirstLoadKb": 585,
    "maxServerTraceMb": 260,
    "nearServerTraceMb": 10,
    "bannedServerTracePatterns": [
      "private/recon/"
    ],
    "nearBudgetKb": 4,
    "failOnWarnings": false
  }
}
