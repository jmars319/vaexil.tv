{
  "name": "vaexil.tv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port ${PORT:-3203}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "rm -rf .next/dev && next typegen && tsc --noEmit",
    "audit:maintainability": "node scripts/audit-maintainability.mjs",
    "audit:recon-se3-mapgenie": "node scripts/audit-mapgenie-sniper-elite-markers.mjs --game sniper-elite-3 --require-details",
    "audit:recon-se4-mapgenie": "node scripts/audit-mapgenie-sniper-elite-markers.mjs --game sniper-elite-4 --require-details",
    "audit:recon-se5-g4g": "node scripts/audit-g4g-sniper-elite-markers.mjs --game sniper-elite-5",
    "audit:recon-ser-g4g": "node scripts/audit-g4g-sniper-elite-markers.mjs --game sniper-elite-resistance",
    "import:recon-se3-mapgenie-details": "node scripts/import-mapgenie-sniper-elite-marker-details.mjs --game sniper-elite-3 --write",
    "import:recon-se4-mapgenie-details": "node scripts/import-mapgenie-sniper-elite-marker-details.mjs --game sniper-elite-4 --write",
    "import:recon-se5-g4g-details": "node scripts/import-g4g-sniper-elite-marker-details.mjs --game sniper-elite-5 --write",
    "import:recon-ser-g4g-details": "node scripts/import-g4g-sniper-elite-marker-details.mjs --game sniper-elite-resistance --write",
    "budget:bundle": "node scripts/analyze-build.mjs",
    "test:selectors": "node scripts/verify-playwright-selectors.mjs",
    "test:guardrails": "node scripts/verify-test-guardrails.mjs",
    "test:flake-report": "node scripts/report-playwright-flakes.mjs",
    "security:local": "just security",
    "test:static": "bash scripts/test-static.sh",
    "test:unit": "node scripts/test-recon-invariants.mjs",
    "test:e2e": "env -u NO_COLOR FORCE_COLOR=0 playwright test",
    "test:deploy": "npm run lint && npm run typecheck && npm run build && npm run audit:maintainability -- --strict && npm run budget:bundle",
    "test:all": "bash scripts/test-all.sh",
    "doctor": "bash scripts/doctor.sh",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run audit:maintainability -- --strict && npm run budget:bundle && bash scripts/dev-verify.sh",
    "dev:start": "bash scripts/dev-start.sh",
    "dev:test": "bash scripts/dev-test.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:restart": "bash scripts/dev-restart.sh",
    "dev:status": "bash scripts/dev-status.sh",
    "db:seed": "node scripts/seed.mjs",
    "recon:upload-assets": "node scripts/upload-recon-assets-to-r2.mjs",
    "cdn:purge": "node scripts/purge-cdn-cache.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@libsql/client": "^0.17.3",
    "@sendgrid/mail": "^8.1.6",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "overrides": {
    "axios": "1.18.0",
    "brace-expansion@1.1.14": "1.1.16",
    "brace-expansion@5.0.6": "5.0.7",
    "postcss": "8.5.14",
    "sharp": "0.35.0"
  }
}
